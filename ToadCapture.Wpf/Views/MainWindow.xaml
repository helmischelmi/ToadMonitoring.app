<Window x:Class="ToadCapture.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Erdkroeten-Erfassung"
        Height="900"
        Width="1560"
        WindowStartupLocation="CenterScreen"
        Background="#0E1116"
        Foreground="White"
        KeyDown="Window_OnKeyDown">
    <Grid Margin="18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="1.4*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="Nacht-Erfassung Grosse Scheidegg" FontSize="34" FontWeight="Bold" />

        <Border Grid.Row="1"
                Grid.ColumnSpan="2"
                Background="{Binding StatusColor}"
                CornerRadius="8"
                Margin="0,12,0,0"
                Padding="14">
            <TextBlock Text="{Binding StatusMessage}" FontSize="30" FontWeight="Bold" Foreground="Black" />
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,16,0,0">
            <Button Content="Mode 1: Vorsortierung solo M" Command="{Binding SetMode1Command}" Background="#2B4259" />
            <Button Content="Mode 2: Erfassung M/W/Paar" Command="{Binding SetMode2Command}" Background="#325B3B" />
            <Button Content="Export" Command="{Binding ExportCommand}" Background="#655430" />
        </StackPanel>

        <UniformGrid Grid.Row="3" Grid.ColumnSpan="2" Columns="5" Margin="0,14,0,0">
            <Border Background="#1D3653" Padding="10" Margin="4">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="New M  " VerticalAlignment="Bottom" />
                    <TextBlock Text="{Binding KpiNewM}" FontSize="30" />
                </StackPanel>
            </Border>
            <Border Background="#1D3653" Padding="10" Margin="4">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="New W  " VerticalAlignment="Bottom" />
                    <TextBlock Text="{Binding KpiNewW}" FontSize="30" />
                </StackPanel>
            </Border>
            <Border Background="#1D3653" Padding="10" Margin="4">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Existing  " VerticalAlignment="Bottom" />
                    <TextBlock Text="{Binding KpiExisting}" FontSize="30" />
                </StackPanel>
            </Border>
            <Border Background="#1D3653" Padding="10" Margin="4">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Pairs  " VerticalAlignment="Bottom" />
                    <TextBlock Text="{Binding KpiPairs}" FontSize="30" />
                </StackPanel>
            </Border>
            <Border Background="#1D3653" Padding="10" Margin="4">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Today total  " VerticalAlignment="Bottom" />
                    <TextBlock Text="{Binding KpiTotal}" FontSize="30" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <Grid Grid.Row="4" Grid.Column="0" Margin="0,14,14,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Text="Chip-ID" FontSize="24" />
            <TextBox Grid.Row="1"
                     Text="{Binding ChipInput, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="28"
                     KeyDown="ChipTextBox_OnKeyDown" />

            <StackPanel Grid.Row="2" Orientation="Horizontal">
                <Button Content="Lookup/Prepare" Command="{Binding LookupChipCommand}" Background="#38508E" />
                <Button Content="Kein Chip / neu chippen" Command="{Binding NoChipCommand}" Background="#9B2A2A" />
            </StackPanel>

            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,8,0,0">
                <TextBlock Text="Sex" VerticalAlignment="Center" />
                <ToggleButton Content="M" IsChecked="{Binding IsMaleSelected}" Width="90" Height="52" FontSize="26" />
                <ToggleButton Content="W" IsChecked="{Binding IsFemaleSelected}" Width="90" Height="52" FontSize="26" />
            </StackPanel>

            <Grid Grid.Row="4" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Gewicht (g)" />
                    <TextBox Text="{Binding WeightInput, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Laenge (cm)" />
                    <TextBox Text="{Binding LengthInput, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="5">
                <TextBlock Text="Bemerkung" />
                <TextBox Text="{Binding Remark, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <StackPanel Grid.Row="6" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,12,0,0">
                <Button Content="Paar Teil 1 merken" Command="{Binding RememberPairPart1Command}" Margin="0 5" Background="#536428" />
                <Button Content="Speichern" Command="{Binding SaveObservationCommand}" FontSize="28" Background="#198754" />
            </StackPanel>
        </Grid>

        <DataGrid Grid.Row="4"
                  Grid.Column="1"
                  Margin="0,14,0,0"
                  ItemsSource="{Binding RecentRows}"
                  SelectedItem="{Binding SelectedRow}"
                  RowHeight="44"
                  FontSize="18"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Zeit" Binding="{Binding RecordedAt}" Width="150" />
                <DataGridTextColumn Header="Chip" Binding="{Binding ChipId}" Width="180" />
                <DataGridTextColumn Header="Sex" Binding="{Binding Sex}" Width="60" />
                <DataGridTextColumn Header="Gew." Binding="{Binding Weight}" Width="80" />
                <DataGridTextColumn Header="Laenge" Binding="{Binding Length}" Width="80" />
                <DataGridTextColumn Header="Partner" Binding="{Binding PartnerChipId}" Width="180" />
                <DataGridTextColumn Header="Bemerkung" Binding="{Binding Remark}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
